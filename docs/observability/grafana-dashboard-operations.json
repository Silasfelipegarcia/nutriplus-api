      "targets": [
        {
          "expr": "sum by (flow) (rate(nutriplus_http_server_duration_seconds_count{sync=\"true\",status=~\"5..\"}[5m])) / sum by (flow) (rate(nutriplus_http_server_duration_seconds_count{sync=\"true\"}[5m]))",
