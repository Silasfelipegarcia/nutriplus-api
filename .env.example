# Variáveis de ambiente — Nutri+ API
# Mesmo MySQL local do Hosty (127.0.0.1:3306), banco separado: nutriplus

DB_URL=jdbc:mysql://127.0.0.1:3306/nutriplus?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=

# Base64 (mín. 32 bytes decodificados) — igual ao padrão Hosty
JWT_SECRET=bnV0cmlwbHVzLWRldi1zZWNyZXQta2V5LW1pbmltdW0tMzItYnl0ZXM=
AI_AGENT_URL=http://localhost:8000
# Shared secret API → agente (homolog/prod: same value on both services)
AI_AGENT_INTERNAL_TOKEN=

# Prometheus scrape without user JWT
METRICS_SCRAPE_TOKEN=

# Produção/homolog (Railway) — use referências ao plugin MySQL do mesmo projeto:
# SPRING_PROFILES_ACTIVE=prod
# DB_URL=jdbc:mysql://${{MYSQLHOST}}:${{MYSQLPORT}}/${{MYSQLDATABASE}}?useSSL=true&requireSSL=true&serverTimezone=UTC&characterEncoding=utf8
# DB_USERNAME=${{MYSQLUSER}}
# DB_PASSWORD=${{MYSQLPASSWORD}}
# JWT_SECRET=<openssl rand -base64 32>
# AI_AGENT_URL=https://seu-agente.up.railway.app
# AI_AGENT_INTERNAL_TOKEN=<mesmo INTERNAL_TOKEN do agente>
# CORS_ALLOWED_ORIGINS=https://nutriplus-web-ten.vercel.app,https://nutriplus-web.vercel.app

# Stripe (Nutri+ Pro)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MOCK_MODE=true
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/pro/settings
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/pro/settings

# URL base do portal pro (convites)
NUTRIPLUS_PRO_INVITE_BASE_URL=http://localhost:3000

SPRING_PROFILES_ACTIVE=local,dev

# Idempotência — local/dev desligado para não travar localhost
IDEMPOTENCY_ENABLED=false
IDEMPOTENCY_REQUIRE_KEY=false
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_IN_PROGRESS_TIMEOUT=120
